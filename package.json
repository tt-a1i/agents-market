{
  "name": "@agents-market/cli",
  "version": "0.1.0",
  "description": "Agent-native marketplace and installer for specialized coding subagents.",
  "type": "module",
  "packageManager": "npm@10.9.8",
  "bin": {
    "agents-market": "./dist/index.js"
  },
  "files": [
    "dist",
    "registry",
    "docs",
    "integrations",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "registry:check": "npm run build && node scripts/registry-submission-check.mjs",
    "release:artifacts": "node scripts/build-release-artifacts.mjs",
    "release:check": "node scripts/release-check.mjs",
    "prepack": "npm run build && node dist/index.js registry lint --strict"
  },
  "keywords": [
    "agents",
    "subagents",
    "claude-code",
    "codex",
    "opencode",
    "cli"
  ],
  "author": "Agents Market contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tt-a1i/agents-market.git"
  },
  "bugs": {
    "url": "https://github.com/tt-a1i/agents-market/issues"
  },
  "homepage": "https://tt-a1i.github.io/agents-market/",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "picocolors": "^1.1.1",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  }
}
